RUNTIME_MODE=GOLDEN_REPLAY
DATABASE_URL=postgresql://onlyboth:local-development-only@127.0.0.1:5432/onlyboth
REPLAY_ID=payment-retry-v1
PUBLIC_EXPLORE_SEED=onlyboth-buildweek-v1
SANDBOX_ADAPTER=replay
DEMO_MODE=true
# Generate a local secret with at least 32 characters. Never commit a deployed secret.
DEMO_SESSION_SECRET=replace-with-a-local-secret-at-least-32-characters

# Destructive PostgreSQL acceptance tests require an explicitly named test database.
TEST_DATABASE_URL=postgresql://onlyboth:local-development-only@127.0.0.1:5432/onlyboth_test

# Private Object Storage (local MinIO; production can use S3/R2 through the same port).
OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_BUCKET=onlyboth-private
OBJECT_STORE_ACCESS_KEY_ID=onlyboth-local
OBJECT_STORE_SECRET_ACCESS_KEY=onlyboth-local-development-secret
# Local MinIO uses path-style URLs. Railway Buckets require false (virtual-hosted style).
OBJECT_STORE_FORCE_PATH_STYLE=true
# Comma-separated browser origins allowed to use presigned uploads.
OBJECT_STORE_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# LIVE Worker only. Supply this in the process environment; never commit a value here.
# OPENAI_API_KEY=

# Employer AI Review Analyst platform kill switch. Default is closed.
EMPLOYER_REVIEW_AI_ENABLED=false
# LIVE never falls back. SYNTHETIC is permitted only for clearly disclosed local demos/tests.
EMPLOYER_REVIEW_AI_MODE=LIVE
# Explicit allowlisted Worker model. The production default remains Sol.
EMPLOYER_REVIEW_AI_MODEL=gpt-5.6-luna

# Optional synthetic reset override used only to exercise the consent-gated policy-on UI.
# DEMO_EMPLOYER_AI_REVIEW_POLICY=ANSWER_PLUS_PROCESS
