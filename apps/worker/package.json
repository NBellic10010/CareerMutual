{
  "name": "@onlyboth/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "smoke": "tsx src/index.ts --smoke",
    "once": "tsx src/index.ts --once",
    "migrate": "tsx src/index.ts --migrate",
    "demo:reset": "tsx src/index.ts --demo-reset",
    "demo:reset:matching": "tsx src/index.ts --demo-reset-matching",
    "live:smoke": "tsx src/index.ts --live-smoke",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@onlyboth/application": "workspace:*",
    "@onlyboth/ai": "workspace:*",
    "@onlyboth/challenge-catalog": "workspace:*",
    "@onlyboth/db": "workspace:*",
    "@onlyboth/sandbox": "workspace:*",
    "@onlyboth/storage": "workspace:*",
    "pg": "8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
